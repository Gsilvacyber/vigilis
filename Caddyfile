# Caddyfile for SOCAI production deployment
# 1. Replace "your-domain.example.com" with your actual domain
# 2. Replace email with your real contact (for Let's Encrypt)
# 3. Run: docker compose -f docker-compose.yml -f docker-compose.prod.yml --profile prod up -d

{
    email admin@example.com
}

your-domain.example.com {
    reverse_proxy backend:8000
    encode gzip zstd
    header {
        Strict-Transport-Security "max-age=31536000;"
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }
    log {
        output stdout
        format console
    }
}
