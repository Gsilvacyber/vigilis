APP_ENV=local
APP_PORT=8000

# --- Database ---
# Postgres (default for production / Docker):
DATABASE_URL=postgresql+psycopg2://socai:socai@localhost:5432/socai
# SQLite (no-Docker local dev -- uncomment below and comment out Postgres line):
# DATABASE_URL=sqlite:///local.db

# Default webhook target -- points to built-in echo stub for local dev
WEBHOOK_DEFAULT_URL=http://localhost:8000/debug/webhook-echo

# If true, app creates tables at startup (MVP convenience; for production use Alembic)
APP_CREATE_TABLES=true

# --- API auth ---
# Demo API key. MUST be rotated for any non-local deployment.
# Generate with: openssl rand -hex 32
DEMO_API_KEY=socai-demo-key-do-not-use-in-production

# ============================================================================
# Docker deployment settings (used by docker-compose.yml)
# ----------------------------------------------------------------------------
# REQUIRED for any non-localhost deployment. The compose file provides
# dev-friendly defaults so `docker compose up` works out-of-the-box, but for
# production you MUST override POSTGRES_PASSWORD and DEMO_API_KEY below.
# ============================================================================
POSTGRES_USER=socai
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=socai
APP_PORT=8000

# --- Scalability tuning ---
# Time window (minutes) for grouping related alerts into a single case.
# Larger values group more alerts together; smaller values create more cases.
GROUPING_WINDOW_MINUTES=60

# Time window (hours) for correlating cases into incidents.
# Controls how far back the incident correlator looks for related cases.
CORRELATION_WINDOW_HOURS=24

# --- Threat Intelligence Providers (optional) ---
# VirusTotal API v3 key (free tier: 4 req/min, 500 req/day)
# Get yours at: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=

# AbuseIPDB API key (free tier: 1000 checks/day)
# Get yours at: https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=

# --- Distributed Rate Limiting (optional) ---
# Redis URL for multi-worker rate limiting. If unset, rate limiting
# uses in-process memory (fine for single-worker deployments).
# Example: redis://localhost:6379/0
REDIS_URL=
